SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-public-anon-key

# Solo NeuroMood Hub profesional. No usar en Suite/paciente ni en builds publicos.
SUPABASE_HUB_KEY=

# Token de sesión Supabase Auth (efímero). Se almacena en SQLite local, no en .env.
# Solo para QA local si se necesita pre-cargar una sesión. No commitear valores reales.
NM_HUB_ACCESS_TOKEN=
NM_HUB_REFRESH_TOKEN=

GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_API_KEY=
OPENAI_API_KEY=
